<ContentDialog
    x:Class="OmniConsole.Dialogs.PlatformEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Style="{StaticResource DefaultContentDialogStyle}"
    DefaultButton="Primary"
    RequestedTheme="Dark">

    <StackPanel Width="400">

        <!-- 平台名稱 -->
        <TextBlock x:Name="NameLabel" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" MaxLength="50" Margin="0,0,0,4"/>
        <TextBlock x:Name="NameError" FontSize="12" Foreground="Red"
                   Visibility="Collapsed" Margin="0,0,0,8"/>

        <!-- 啟動類型 -->
        <TextBlock x:Name="LaunchTypeLabel" Margin="0,0,0,4"/>
        <ComboBox x:Name="LaunchTypeCombo" HorizontalAlignment="Stretch" Margin="0,0,0,12"/>

        <!-- 目標 URI / 路徑 -->
        <TextBlock x:Name="TargetLabel" Margin="0,0,0,4"/>
        <Grid x:Name="TargetRow" Margin="0,0,0,4" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="TargetBox" Grid.Column="0" MaxLength="2048" Margin="0"/>
            <Button x:Name="BrowseExeButton" Grid.Column="1" Content="..."
                    Padding="12,6,12,6" VerticalAlignment="Center" Visibility="Collapsed"/>
        </Grid>
        <TextBlock x:Name="BrowseExeGamepadWarning" FontSize="12" TextWrapping="Wrap"
                   Foreground="Orange" Margin="0,2,0,4" Visibility="Collapsed"/>
        <TextBlock x:Name="TargetError" FontSize="12" Foreground="Red"
                   Visibility="Collapsed" Margin="0,0,0,8"/>

        <!-- 啟動參數（執行檔模式） -->
        <TextBlock x:Name="ArgsLabel" Margin="0,0,0,4" Visibility="Collapsed"/>
        <TextBox x:Name="ArgsBox" MaxLength="500" Margin="0,0,0,4" Visibility="Collapsed"/>
        <TextBlock x:Name="ArgsError" FontSize="12" Foreground="Red"
                   Visibility="Collapsed" Margin="0,0,0,8"/>

        <!-- 封裝應用程式 -->
        <TextBlock x:Name="PackagedAppWarning" FontSize="12" TextWrapping="Wrap"
                   Foreground="Orange" Margin="0,0,0,4" Visibility="Collapsed"/>
        <TextBlock x:Name="PackagedAppLabel" Margin="0,0,0,4" Visibility="Collapsed"/>
        <AutoSuggestBox x:Name="PackagedAppSuggestBox" Margin="0,0,0,4" Visibility="Collapsed"/>
        <TextBlock x:Name="PackagedAppError" FontSize="12" Foreground="Red"
                   Visibility="Collapsed" Margin="0,0,0,8"/>

        <!-- 卡片背景圖 -->
        <TextBlock x:Name="IconLabel" Margin="0,0,0,4"/>
        <TextBlock x:Name="IconHint" FontSize="12" Foreground="Gray" Margin="0,0,0,4"/>
        <Grid x:Name="IconRow" Margin="0,0,0,12" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="IconFileNameText" Grid.Column="0" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="13"/>
            <Button x:Name="BrowseIconButton" Grid.Column="1" Content="..."
                    Padding="12,6,12,6" VerticalAlignment="Center"/>
        </Grid>
        <TextBlock x:Name="BrowseIconGamepadWarning" FontSize="12" TextWrapping="Wrap"
                   Foreground="Orange" Margin="0,2,0,4"/>

        <!-- 實驗性功能警告 -->
        <TextBlock x:Name="ConfigWarning" FontSize="12" TextWrapping="Wrap"
                   Foreground="Orange" Margin="0,4,0,0"/>

    </StackPanel>
</ContentDialog>
